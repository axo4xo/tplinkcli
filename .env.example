# TP-Link router target
ROUTER_IP=192.168.0.1

# Preferred: let the CLI perform the login handshake itself.
ROUTER_USERNAME=admin
ROUTER_PASSWORD=

# Alternative: snapshot the browser's localStorage after login.
# These ROTATE every session — copy fresh from localStorage each time.
# ENCRYPTOR_AES=k=<16 digits>&i=<16 digits>
# ENCRYPTOR_HASH=<md5 hex>
# ENCRYPTOR_SEQ=<int>
# ENCRYPTOR_RSA=nn=<modulus hex>&ee=010001
